{
  "name": "homebrew",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "node lint.mjs",
    "typecheck": "node --experimental-default-type=module typecheck.mjs",
    "build:verify": "node build-verify.mjs",
    "test": "node --experimental-default-type=module run-tests.mjs",
    "qa": "npm run lint && npm run typecheck && npm test && npm run build && npm run build:verify"
  },
  "dependencies": {
    "spin-wheel": "^5.0.2"
  },
  "devDependencies": {
    "vite": "^8.1.5"
  }
}
